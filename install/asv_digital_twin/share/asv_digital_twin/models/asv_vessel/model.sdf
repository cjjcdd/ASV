<?xml version="1.0"?>
<sdf version="1.9">
  <model name="asv_vessel">
    <static>false</static>
    <gravity>false</gravity> <self_collide>false</self_collide>
    
    <link name="base_link">
      <inertial>
        <mass>50.0</mass>
        <inertia>
          <ixx>10.0</ixx> <ixy>0</ixy> <ixz>0</ixz>
          <iyy>40.0</iyy> <iyz>0</iyz>
          <izz>45.0</izz>
        </inertia>
      </inertial>

      <visual name="hull_visual">
        <pose>0 0 -0.5 0 0 0</pose> 
        <geometry>
          <mesh>
            <uri>model://asv_vessel/meshes/hull.stl</uri>
            <scale>10 10 10</scale> 
          </mesh>
        </geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>

      <collision name="hull_collision">
        <pose>0 0 -0.5 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://asv_vessel/meshes/hull.stl</uri>
            <scale>10 10 10</scale>
          </mesh>
        </geometry>
      </collision>

      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <topic>asv/sensors/imu</topic>
      </sensor>

      <sensor name="navsat_sensor" type="navsat">
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <topic>asv/sensors/gps</topic>
      </sensor>

      <sensor name="camera_sensor" type="camera">
        <pose>10.0 0 5.0 0 0 0</pose>
        <topic>asv/sensors/camera</topic>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.57</horizontal_fov>
          <image><width>1280</width><height>720</height></image>
        </camera>
      </sensor>

      <sensor name="radar_proxy" type="gpu_lidar">
        <pose>0 0 6.0 0 0 0</pose>
        <topic>asv/sensors/radar</topic>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal><samples>720</samples><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal>
            <vertical><samples>1</samples></vertical>
          </scan>
          <range><min>2.0</min><max>150.0</max></range>
        </ray>
      </sensor>
    </link>

    <link name="propeller_link">
      <pose>-15.0 0 -2.0 0 0 0</pose> 
      <visual name="engine_visual">
        <geometry>
          <mesh>
            <uri>model://asv_vessel/meshes/engine.dae</uri>
            <scale>3 3 3</scale> </mesh>
        </geometry>
      </visual>
      <visual name="prop_visual">
        <pose>-0.8 0 -0.3 0 0 0</pose> 
        <geometry>
          <mesh>
            <uri>model://asv_vessel/meshes/propeller.dae</uri>
            <scale>3 3 3</scale>
          </mesh>
        </geometry>
      </visual>
    </link>

    <joint name="azimuth_joint" type="revolute">
      <parent>base_link</parent>
      <child>propeller_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-3.14</lower><upper>3.14</upper></limit>
      </axis>
    </joint>
  </model>
</sdf>